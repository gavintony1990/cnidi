{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm run lint)",
      "Bash(npm run typecheck)",
      "Bash(npm run build)",
      "Bash(mvn test)",
      "Bash(mvn package)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)"
    ]
  },
  "env": {
    "PROJECT_DOCS_ROOT": "./.claude/docs"
  },
  "enabledMcpjsonServers": [
    "github"
  ]
}
